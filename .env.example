# Gemini API Key for Syllabus Parsing and Verification
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (Docker Compose default)
DATABASE_URL=postgresql://erasmus:erasmus_dev@localhost:5600/erasmus_match

# JWT Secret for Session & Authorization Authentication
JWT_SECRET=your_jwt_secret_key_here

# Default Super Admin Password (for first run setup)
ADMIN_PASSWORD=your_secure_admin_password_here

# Celery Task Queue Configuration
USE_CELERY=true

# Frontend API URL
VITE_API_URL=/api
